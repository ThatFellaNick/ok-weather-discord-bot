# US Weather Discord Bot

# Copy this file to .env and fill in your values.
# Never commit .env or real Discord webhook URLs.

# Discord Webhooks

# Discord webhook used for daily briefings, startup messages, test briefings,
# and manual trigger_brief posts.
BRIEF_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME

# Optional additional brief webhooks. Separate multiple URLs with commas or spaces.
BRIEF_WEBHOOK_URLS=

# Discord webhook used for NWS alert posts and SPC RSS item posts.
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME

# Optional additional alert webhooks. Separate multiple URLs with commas or spaces.
ALERT_WEBHOOK_URLS=

# NWS API

# NWS requests should identify the app and include a contact email.
NWS_USER_AGENT=ok-weather-discord-bot/1.0 (your_email@example.com)

# Target Area

# Human-readable name used in Discord messages.
TARGET_NAME=Oklahoma

# Target mode:
# state = monitor one or more full states from TARGET_STATES
# radius = monitor within TARGET_RADIUS_MILES of TARGET_POINTS
TARGET_MODE=state

# State abbreviations used for NWS active alert polling. Use commas for more
# than one state, such as KS,MO. In radius mode, include nearby border states
# when the radius crosses a state line.
TARGET_STATES=OK

# Labeled forecast/radius points. Use semicolons between places:
# Name:latitude,longitude;Other Name:latitude,longitude
# Required for radius mode. Optional in state mode, but useful for city
# snapshots and auto-detecting AFD/radar settings.
TARGET_POINTS=OKC:35.4676,-97.5164;Tulsa:36.1540,-95.9928;Lawton:34.6036,-98.3959

# Used only in radius mode. Set the mile radius around TARGET_POINTS.
TARGET_RADIUS_MILES=0

# Optional SPC GIS query envelope as west,south,east,north. Leave blank to use
# built-in state boxes or a box generated from TARGET_POINTS plus radius.
TARGET_BBOX=

# Scheduling

# Container/local timezone used for brief scheduling and displayed times.
TZ=America/Chicago

# Main polling loop interval, in seconds.
POLL_SECONDS=180

# Maximum attempts for each NWS/SPC source fetch.
HTTP_MAX_RETRIES=3

# Severe Thunderstorm Warning alert behavior:
# all = post every NWS Severe Thunderstorm Warning
# high_end = only post warnings with stronger hail/wind/destructive wording
SEVERE_THUNDERSTORM_WARNING_MODE=all

# Daily brief time in TZ.
BRIEF_HOUR=9
BRIEF_MINUTE=0

# Rest-of-day severe weather brief time in TZ.
AFTERNOON_SEVERE_BRIEF_ENABLED=true
AFTERNOON_SEVERE_BRIEF_HOUR=15
AFTERNOON_SEVERE_BRIEF_MINUTE=30

# Storage

# Persistent JSON dedupe and scheduling state.
STATE_FILE=/data/state.json

# Log file path inside the container.
LOG_FILE=/data/weather.log

# Optional Features

# Docker image used by docker-compose.yml. Leave this on latest for normal use,
# or pin a release tag after images are published.
BOT_IMAGE=thatfellanick/ok-weather-discord-bot:latest

# Send a one-time startup message to BRIEF_WEBHOOK_URL.
SEND_STARTUP_MESSAGE=true

# Send a brief immediately when the container starts.
TEST_BRIEF_ON_START=false

# Manual Trigger

# Create this file to request a manual briefing. The bot removes it after a
# successful post.
TRIGGER_BRIEF_FILE=/data/trigger_brief

# Create this file to send a test post to ALERT_WEBHOOK_URL.
TRIGGER_ALERT_TEST_FILE=/data/trigger_alert_test

# Forecast discussions

# NWS forecast offices used for the Forecaster Notes briefing section. Leave
# blank to auto-detect from TARGET_POINTS using NWS point metadata. Set
# comma-separated offices to override, such as OUN,TSA.
AFD_OFFICES=

# Brief imagery

# Include SPC outlook map images, SPC RSS item images, and radar loop embeds.
INCLUDE_BRIEF_IMAGES=true

# Radar stations used when active notable alerts are in effect. Leave blank to
# auto-detect from TARGET_POINTS using NWS point metadata. Set comma-separated
# radar IDs to override, such as KTLX,KINX,KFDR.
RADAR_STATIONS=

# Discord delivery

# Maximum Discord webhook attempts for each post.
DISCORD_MAX_RETRIES=3
